\@writefile{lof}{\contentsline {figure}{\numberline {3.4}{\ignorespaces (a) The electron power spectrum in the Limber approximation for the redshift bins considered in this thesis. The color coding represents the effective redshift of every bin as calculated by Eq. \ref {eq:z_eff}. (b) A comparison between the Limber and the non-Limber approximations for the electron power spectrum. The two calculations agree for large values of $\ell $. Non-Limber integral is done via the Levin approximation using \blx@tocontentsinit {0}\cite {reischke2025pylevin}.}}{47}{figure.caption.20}\protected@file@percent }
\newlabel{meth_fig:cls}{{3.4}{47}{(a) The electron power spectrum in the Limber approximation for the redshift bins considered in this thesis. The color coding represents the effective redshift of every bin as calculated by Eq. \ref {eq:z_eff}. (b) A comparison between the Limber and the non-Limber approximations for the electron power spectrum. The two calculations agree for large values of $\ell $. Non-Limber integral is done via the Levin approximation using \cite {reischke2025pylevin}}{figure.caption.20}{}}
\newlabel{meth_fig:cls@cref}{{[figure][4][3]3.4}{[1][47][]47}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.5}{\ignorespaces A plot showing the ratio $R$ between neighboring shells for 29 redshift bins. The ratio is less than $0.1$ for all values of $\ell $, which means that the correlation between neighboring shells is small enough to be ignored in this work. The spectra are obtained using the non-Limber expression of the power spectrum.}}{47}{figure.caption.21}\protected@file@percent }
\newlabel{meth_fig:cls_shells_compared}{{3.5}{47}{A plot showing the ratio $R$ between neighboring shells for 29 redshift bins. The ratio is less than $0.1$ for all values of $\ell $, which means that the correlation between neighboring shells is small enough to be ignored in this work. The spectra are obtained using the non-Limber expression of the power spectrum}{figure.caption.21}{}}
\newlabel{meth_fig:cls_shells_compared@cref}{{[figure][5][3]3.5}{[1][47][]47}{}{}{}}
