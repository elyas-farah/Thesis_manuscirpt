\@writefile{lof}{\contentsline {figure}{\numberline {2.5}{\ignorespaces A plot showing the gas linear power spectrum, the one-halo, the two-halo, and the non-linear power spectrum, and the linear matter power spectrum. For small $k$, the two-halo term dominates the power spectrum, while for large $k$, the one-halo term dominates the power spectrum. In calculating the non-linear power spectrum, the one-halo term is supressed on larger large scales to remove the contribution of shot noise arising from assuming that halos are infinitely small point on larger scales. The power spectrum is obtained using the halo model formalism described in this section, and the halo profile is obtained using the baryonfication correction model described in section \ref {theory_sec:BF}. I use the cosmological parameters listed in table \ref {tab:cosmo_params}. The gas power spectrum converges to the linear matter power spectrum on large scales is modified on small scales due to the impact of baryonic feedback.}}{23}{figure.caption.6}\protected@file@percent }
\newlabel{theory_fig:halo_model}{{2.5}{23}{A plot showing the gas linear power spectrum, the one-halo, the two-halo, and the non-linear power spectrum, and the linear matter power spectrum. For small $k$, the two-halo term dominates the power spectrum, while for large $k$, the one-halo term dominates the power spectrum. In calculating the non-linear power spectrum, the one-halo term is supressed on larger large scales to remove the contribution of shot noise arising from assuming that halos are infinitely small point on larger scales. The power spectrum is obtained using the halo model formalism described in this section, and the halo profile is obtained using the baryonfication correction model described in section \ref {theory_sec:BF}. I use the cosmological parameters listed in table \ref {tab:cosmo_params}. The gas power spectrum converges to the linear matter power spectrum on large scales is modified on small scales due to the impact of baryonic feedback}{figure.caption.6}{}}
\newlabel{theory_fig:halo_model@cref}{{[figure][5][2]2.5}{[1][22][]23}{}{}{}}
